  "bugs": "https://github.com/harfbuzz/harfbuzzjs/issues",
  "homepage": "https://harfbuzz.github.io/harfbuzzjs",
  "devDependencies": {
    "@types/emscripten": "^1.41.5",
    "@types/node": "^25.5.0",
    "vitest": "^4.1.2",
    "tsdown": "^0.21.7",
    "typedoc": "^0.28.18",
    "typescript": "^6.0.2",
    "prettier": "^3.8.3"
  }
